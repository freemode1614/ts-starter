{
  "name": "ts-starter",
  "version": "0.1.0",
  "description": "Project starter for TypeScript",
  "license": "MIT",
  "type": "module",
  "audits": true,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "test": "vitest --watch=false",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write ."
  },
  "keywords": [
    "ts-starter",
    "typescript library",
    "typescript library template"
  ],
  "exports": {
    "./package.json": "./package.json",
    "./*": {
      "types": "./npm/*.d.mts",
      "import": "./npm/*.mjs"
    },
    ".": {
      "types": "./npm/index.d.mts",
      "import": "./npm/index.mjs"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@changesets/cli": "^2.29.4",
    "@rollup/plugin-alias": "^6.0.0",
    "@types/node": "^20.17.50",
    "tsdown": "0.21.0-beta.2",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@10.9.0"
}
